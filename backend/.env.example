# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/mastergo_db

# JWT Secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Master Key for wallet encryption (generate with: openssl rand -base64 32 | head -c 32)
# Must be exactly 32 bytes when base64 decoded
MASTER_KEY=your_base64_encoded_32_bytes_key

# Redis Configuration
REDIS_URL=localhost:6379


ETH_RPC_URL=http://localhost:8545


PORT=8080

# Frontend URL
FRONTEND_URL=http://localhost:3000



SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-login
SMTP_PASSWORD=your-brevo-smtp-key
FROM_EMAIL=noreply@example.com

